# FocusOn Frontend Environment Variables
# Copy this to .env.local and fill in your values

# Development: leave REACT_APP_API_URL unset to use same-origin /api (CRA proxy → port 8000).
# Production: set your deployed API, e.g. https://api.example.com/api
# REACT_APP_API_URL=https://your-api.example.com/api

# App name (used in page titles etc.)
REACT_APP_NAME=FocusOn
